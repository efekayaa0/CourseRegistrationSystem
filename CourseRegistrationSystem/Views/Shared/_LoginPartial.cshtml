@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center gap-2 ms-md-3">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle lp-user-toggle d-flex align-items-center gap-2"
           href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="lp-avatar" aria-hidden="true">
                @(User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
            </span>
            <span class="lp-username d-none d-md-inline">@User.Identity?.Name</span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end lp-dropdown">
            <li>
                <a class="dropdown-item lp-dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                    <svg class="me-2 flex-shrink-0" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    Profilim
                </a>
            </li>
            <li><hr class="dropdown-divider lp-divider" /></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="dropdown-item lp-dropdown-item lp-logout">
                        <svg class="me-2 flex-shrink-0" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Çıkış Yap
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-outline-primary btn-sm px-3" asp-area="Identity" asp-page="/Account/Login">
            Giriş Yap
        </a>
    </li>
    <li class="nav-item">
        <a class="btn btn-accent btn-sm px-3" asp-area="Identity" asp-page="/Account/Register">
            Kayıt Ol
        </a>
    </li>
}
</ul>

<style>
/* Avatar — mor gradient */
.lp-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #6d28d9);
    color: #fff;
    font-weight: 700;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 2px solid #ede9fe;
}

/* Kullanıcı adı — koyu metin (açık navbar) */
.lp-username {
    color: #374151;
    font-size: 0.875rem;
    font-weight: 500;
}

/* Toggle hover */
.lp-user-toggle {
    padding: 0.3rem 0.6rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: #374151;
}
.lp-user-toggle:hover,
.lp-user-toggle.show {
    background: #f5f3ff;
    color: #7c3aed;
    text-decoration: none;
}
.lp-user-toggle:hover .lp-username,
.lp-user-toggle.show .lp-username {
    color: #7c3aed;
}

/* Dropdown — açık tema */
.lp-dropdown {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    box-shadow: 0 8px 24px rgba(0,0,0,.10);
    min-width: 190px;
    padding: 0.4rem;
    margin-top: 0.5rem;
}

.lp-dropdown-item {
    color: #374151;
    border-radius: 0.4rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    transition: background 0.15s, color 0.15s;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    cursor: pointer;
}
.lp-dropdown-item:hover {
    background: #f5f3ff;
    color: #7c3aed;
    text-decoration: none;
}

.lp-divider {
    border-color: #e5e7eb;
    margin: 0.3rem 0;
}

.lp-logout { color: #ef4444; }
.lp-logout:hover { background: #fef2f2 !important; color: #dc2626 !important; }
</style>
