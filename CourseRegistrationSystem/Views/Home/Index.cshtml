@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- ===== HERO ===== -->
<section class="hero-section">
    <div class="container position-relative">
        <div class="hero-badge mb-3">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
            Ders Kayıt Sistemi
        </div>
        <h1>Derslerinizi Kolayca<br class="d-none d-md-block" /> Planlayın ve Kayıt Olun</h1>
        <p class="lead">
            Modern ve kullanıcı dostu arayüzümüzle ders programınızı oluşturun,<br class="d-none d-lg-block" />
            kayıt işlemlerinizi hızlıca tamamlayın ve akademik takviminizi yönetin.
        </p>
        <div class="d-flex flex-wrap gap-3 justify-content-center">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-accent btn-lg">
                Hemen Başla &rarr;
            </a>
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="btn btn-outline-light btn-lg">
                Daha Fazla Bilgi
            </a>
        </div>
    </div>
</section>

<!-- ===== NASIL ÇALIŞIR? ===== -->
<section class="steps-section">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-badge">Nasıl Çalışır?</div>
            <h2 class="section-title">3 Adımda Kullanmaya Başlayın</h2>
            <p class="text-muted" style="max-width:520px; margin:0 auto; font-size:.97rem;">
                Basit kayıt süreciyle dakikalar içinde sistemi kullanmaya başlayın.
            </p>
        </div>

        <div class="row g-4 position-relative">

            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h5>Hesap Oluşturun</h5>
                    <p>E-posta adresinizle ücretsiz hesap açın ve sisteme güvenli şekilde giriş yapın.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h5>Dersleri İnceleyin</h5>
                    <p>Açık dersleri görüntüleyin, kontenjan ve program bilgilerini anlık takip edin.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h5>Kayıt Olun</h5>
                    <p>Seçtiğiniz derslere birkaç tıkla kayıt olun ve programınızı tamamlayın.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ===== CTA ===== -->
<section class="cta-section">
    <div class="container">
        <div class="cta-card position-relative">
            <div class="position-relative" style="z-index:1;">
                <h3 class="fw-bold mb-2">Hemen Üye Olun</h3>
                <p class="mb-4" style="font-size:.97rem;">
                    Hesap oluşturmak ücretsiz. Ders kaydına dakikalar içinde başlayabilirsiniz.
                </p>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-accent btn-lg px-5">
                    Ücretsiz Kayıt Ol
                </a>
            </div>
        </div>
    </div>
</section>
